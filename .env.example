# Runtime
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
SERVER_CORS_ALLOW_ORIGINS=

# DIAN
DIAN_ENVIRONMENT=habilitacion
DIAN_LOOKUP_ENVIRONMENT=habilitacion
DIAN_LOOKUP_WSDL_URL=
DIAN_CERT_PATH=./certificates/cert.p12
DIAN_CERT_PASSWORD=change-me
DIAN_SOFTWARE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DIAN_SOFTWARE_PIN=12345
DIAN_SOFTWARE_NAME=Facturacion DIAN Kit
DIAN_SOFTWARE_MANUFACTURER_NAME=Example Maintainer
DIAN_SOFTWARE_MANUFACTURER_COMPANY_NAME=Example Company SAS
DIAN_TECHNICAL_KEY=fc8eac422eba16e22ffd8c6f94b3f40a6e38162c
DIAN_TEST_SET_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DIAN_RESOLUTION_PREFIX=FDK
DIAN_RESOLUTION_NUMBER=18760000001
DIAN_RESOLUTION_RANGE_FROM=1
DIAN_RESOLUTION_RANGE_TO=999999
DIAN_RESOLUTION_VALID_FROM=2026-01-01
DIAN_RESOLUTION_VALID_TO=2030-01-01

# Issuer defaults
COMPANY_NAME=Example Issuer SAS
COMPANY_NIT=900123456
COMPANY_DV=7
COMPANY_ADDRESS=Street 10 #20-30
COMPANY_CITY_CODE=11001
COMPANY_CITY_NAME=Bogota
COMPANY_DEPARTMENT_CODE=11
COMPANY_DEPARTMENT_NAME=Bogota D.C.
COMPANY_COUNTRY_CODE=CO
COMPANY_PHONE=3001234567
COMPANY_EMAIL=billing@example-issuer.test
COMPANY_TAX_SCHEME=ZZ
COMPANY_ECONOMIC_ACTIVITY=4752
